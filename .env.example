NODE_ENV=production

# Internal container port.
PORT=3002

# Public host port used by docker-compose.
HOST_PORT=366

APP_NAME=Ariana Asterisk Gateway
APP_BUILD_VERSION=ari-ai-trunk-v1
PUBLIC_BASE_URL=
CORS_ORIGINS=*
LOG_LEVEL=info

# Token used by EVA when it calls this service.
# It must match eva.integracions where codigo = TRUNCAL.
ASTERISK_API_TOKEN=change_me_truncal_token

# EVA callback. This service sends trunk events here.
LARAVEL_API_URL=https://your-crm.example
LARAVEL_API_TOKEN=change_me_truncal_token
LARAVEL_VOICE_TOOLS_TOKEN=
LARAVEL_TENANT_DATABASE=
LARAVEL_TRUNK_EVENTS_ENABLED=true
LARAVEL_TRUNK_EVENTS_PATH=/api/trunk-calls/events
LARAVEL_CALLBACK_TIMEOUT_MS=30000

# OpenAI Realtime for trunk AI mode.
TRUNK_AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRUNK_AI_LANGUAGE=es
TRUNK_AI_REALTIME_CONNECT_TIMEOUT_MS=10000
TRUNK_AI_REALTIME_TOOL_TIMEOUT_MS=12000
TRUNK_AI_INPUT_SAMPLE_RATE=24000
TRUNK_AI_OUTPUT_SAMPLE_RATE=24000
TRUNK_AI_VAD_THRESHOLD=0.65
TRUNK_AI_TURN_SILENCE_MS=500
TRUNK_AI_INTERRUPTION_DEBOUNCE_MS=300

# Asterisk / FreePBX / Grandstream AMI.
PBX_AMI_ENABLED=true
PBX_AMI_HOST=127.0.0.1
PBX_AMI_PORT=5038
PBX_AMI_USERNAME=middleware
PBX_AMI_PASSWORD=change_me
PBX_AMI_RECONNECT=true
PBX_AMI_EVENT_MASK=on
PBX_LOG_TRACKED_EVENTS=true
PBX_LOG_RAW_EVENTS=false
PBX_LOG_VERBOSE_RAW_EVENTS=false
PBX_LOG_LARAVEL_CALLBACKS=true

PBX_MAX_EVENTS=300
PBX_ORIGINATE_CONTEXT=from-internal
PBX_ORIGINATE_PRIORITY=1
PBX_ORIGINATE_TIMEOUT_MS=30000
PBX_CALLER_ID_PREFIX=Ariana
PBX_DIRECT_TRUNK_ENDPOINT=fxo
PBX_HANGUP_CAUSE=16

# Asterisk REST Interface (ARI). Required for browser/AI media bridge.
# Keep disabled until the PBX dialplan sends a test route to Stasis(ARI_APP_NAME).
ARI_ENABLED=false
ARI_BASE_URL=http://127.0.0.1:8088
ARI_WS_URL=
ARI_USERNAME=ariana
ARI_PASSWORD=change_me
ARI_APP_NAME=ariana-trunk
ARI_RECONNECT_MS=3000
ARI_REQUEST_TIMEOUT_MS=15000
ARI_MAX_EVENTS=300
ARI_LARAVEL_EVENTS_ENABLED=false

# Test helpers for the first ARI proof: answer, create bridge, play a sound.
ARI_AUTO_ANSWER=false
ARI_AUTO_BRIDGE=false
ARI_AUTO_PLAYBACK_MEDIA=
ARI_STASIS_REDIRECT_ENABLED=true
ARI_STASIS_CONTEXT=ariana-ari
ARI_STASIS_EXTENSION=s
ARI_STASIS_PRIORITY=1
ARI_STASIS_WAIT_MS=5000
ARI_BRIDGE_WAIT_MS=10000
ARI_EXTERNAL_MEDIA_HOST=127.0.0.1
ARI_EXTERNAL_MEDIA_BIND_HOST=0.0.0.0
ARI_EXTERNAL_MEDIA_PORT_START=46000
ARI_EXTERNAL_MEDIA_PORT_END=46100
ARI_EXTERNAL_MEDIA_FORMAT=ulaw
ARI_EXTERNAL_MEDIA_PAYLOAD_TYPE=0
ARI_EXTERNAL_MEDIA_FRAME_MS=20
