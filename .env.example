NODE_ENV=production

# Internal container port.
PORT=3002

# Public host port used by docker-compose.
HOST_PORT=366

APP_NAME=Ariana Asterisk Gateway
PUBLIC_BASE_URL=
CORS_ORIGINS=*
LOG_LEVEL=info

# Token used by EVA when it calls this service.
# It must match eva.integracions where codigo = TRUNCAL.
ASTERISK_API_TOKEN=change_me_truncal_token

# EVA callback. This service sends trunk events here.
LARAVEL_API_URL=https://your-crm.example
LARAVEL_API_TOKEN=change_me_truncal_token
LARAVEL_TRUNK_EVENTS_ENABLED=true
LARAVEL_TRUNK_EVENTS_PATH=/api/trunk-calls/events
LARAVEL_CALLBACK_TIMEOUT_MS=30000

# Asterisk / FreePBX / Grandstream AMI.
PBX_AMI_ENABLED=true
PBX_AMI_HOST=127.0.0.1
PBX_AMI_PORT=5038
PBX_AMI_USERNAME=middleware
PBX_AMI_PASSWORD=change_me
PBX_AMI_RECONNECT=true
PBX_AMI_EVENT_MASK=on
PBX_LOG_TRACKED_EVENTS=true
PBX_LOG_RAW_EVENTS=false
PBX_LOG_LARAVEL_CALLBACKS=true

PBX_MAX_EVENTS=300
PBX_ORIGINATE_CONTEXT=from-internal
PBX_ORIGINATE_PRIORITY=1
PBX_ORIGINATE_TIMEOUT_MS=30000
PBX_CALLER_ID_PREFIX=Ariana
PBX_DIRECT_TRUNK_ENDPOINT=fxo
PBX_HANGUP_CAUSE=16
